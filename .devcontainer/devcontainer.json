{
    "name": "GraalPy",
	"image": "mcr.microsoft.com/devcontainers/java",
    "remoteEnv": {
        "MX_GLOBAL_ENV": "${containerWorkspaceFolder}/.mxenv",
        "MX_CACHE_DIR": "${containerWorkspaceFolder}/.mxcache",
        "PATH": "${containerEnv:PATH}:${containerWorkspaceFolder}/.mx"
    },
    "postCreateCommand": {
        "install_cmake": "pip install cmake ninja",
        "install_packages": "sudo apt install libffi-dev zlib1g-dev libbz2-dev",
        "setup_mx": "git clone https://github.com/graalvm/mx ${containerWorkspaceFolder}/.mx && mx -y fetch-jdk -A --to ${containerWorkspaceFolder}/.mx --jdk-id labsjdk-ce-latest",
        "setup_mx_env": "echo JAVA_HOME=${containerWorkspaceFolder}/.mx/labsjdk-ce-latest > ${containerWorkspaceFolder}/.mxenv"
    },
    "customizations": {
        "vscode": {
            "extensions": ["vscjava.vscode-java-pack"],
            "settings": { "java.autobuild.enabled": false }
        },
        "codespaces": {
            "openFiles": [
                "docs/contributor/CONTRIBUTING.md"
            ]
        }
    }
}
